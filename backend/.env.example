# Application
APP_NAME=AI Knowledge Base
APP_VERSION=0.1.0
DEBUG=true

# Database
DATABASE_URL=sqlite:///./data/app.db

# ChromaDB
CHROMA_PATH=./data/chroma

# Embedding: hash（Demo 免下载）| chromadb_default（MiniLM，首次需下载模型）
EMBEDDING_MODE=hash
VECTOR_SEARCH_TOP_K=5
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_RETRIES=3
EMBEDDING_CACHE_ENABLED=true

# Hybrid retrieval
HYBRID_RECALL_TOP_K=20
HYBRID_FINAL_TOP_K=5
RRF_K=60

# RAG Prompt
RAG_MAX_HISTORY_TURNS=3
RAG_MAX_CONTEXT_CHARS=6000
RAG_CHUNK_MAX_CHARS=800

# LLM: mock（Demo 免 API）| openai
LLM_MODE=mock
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
LLM_STREAM_DELAY_MS=25
LLM_STREAM_CHUNK_CHARS=2

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM (后续模块使用)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
